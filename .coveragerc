[run]
# Coverage measurement configuration
source = crm_core,CRM
branch = true
omit = 
    */tests/*
    */__pycache__/*
    */migrations/*
    */audit_logs/*
    */frontend/*
    */public_portal/*
    */backend/*

[report]
# Coverage report configuration
exclude_lines =
    pragma: no cover
    def __repr__
    if self\.debug
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__
    pass
    except ImportError:
show_missing = true
precision = 2

[html]
# HTML coverage report configuration
directory = htmlcov
title = RealEstate_CRM Test Coverage

[xml]
# XML coverage report for CI/CD
output = coverage.xml
